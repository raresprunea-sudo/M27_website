{
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/collection$", "dest": "/collection.html" },
    { "src": "^/collection\\.html$", "dest": "/collection.html" },
    { "src": "^/index\\.html$", "dest": "/index.html" },
    { "src": "^/(.+\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|webp))$", "dest": "/$1" },
    { "src": "^/(.*)", "dest": "https://m27.gomag.ro/$1" }
  ]
}